# --- 必須 ---
# PostgreSQL 接続文字列
# 本番: Supabase の Transaction pooler (port 6543) を使う
# 例: postgresql://postgres.xxxx:[PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/cinderella_audition

# Payload のシークレット
# `openssl rand -base64 32` で生成
PAYLOAD_SECRET=

# サイトの公開 URL（管理画面の「公開ページURL」表示や Live Preview に使用）
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# --- 任意 ---
# Google Tag Manager コンテナ ID
NEXT_PUBLIC_GTM_ID=

# Vercel Blob の Read/Write トークン
# Media collection の画像保存に使用。未設定なら画像アップロードは無効
BLOB_READ_WRITE_TOKEN=
